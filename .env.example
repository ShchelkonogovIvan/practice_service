# PostgreSQL used by docker-compose and backend Prisma.
POSTGRES_DB=practice
POSTGRES_USER=practice
POSTGRES_PASSWORD=practice
DATABASE_URL=postgresql://practice:practice@localhost:5432/practice?schema=public

# Backend
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000
APP_URL=http://localhost:3000
PORT=4000

# Optional SMTP notifications
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=Практика <practice@localhost>

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# Optional seed admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin12345
